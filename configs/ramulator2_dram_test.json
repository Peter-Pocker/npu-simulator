{
  "_comment": "Minimal config to test simulator <-> Ramulator2 DRAM interaction. Use with --log-dram or log_dram: true to print DRAM traffic.",
  "num_cores_x": 2,
  "num_cores_y": 2,
  "element_size_bits": 8,
  "core": {
    "mac_units": 256,
    "vector_units": 64,
    "clock_freq_mhz": 1000
  },
  "sram": {
    "size_kb": 512,
    "read_bandwidth_bytes_per_cycle": 64,
    "write_bandwidth_bytes_per_cycle": 64
  },
  "ni": {
    "max_outstanding_reqs": 16,
    "injection_queue_size": 8,
    "ejection_queue_size": 8
  },
  "noc": {
    "flit_size_bytes": 16,
    "hop_latency_cycles": 1,
    "router_latency_cycles": 1,
    "backend": "simple",
    "injection_queue_depth": 16
  },
  "dram": {
    "num_channels": 4,
    "backend": "ramulator2",
    "standard": "DDR4",
    "org": "DDR4_8Gb_x8",
    "timing": "DDR4_2400R",
    "num_ranks": 2,
    "scheduler": "FRFCFS",
    "addr_mapper": "RoBaRaCoCh",
    "frontend_clock_ratio": 4,
    "log_dram": true
  },
  "topology": {
    "dram_controllers": [],
    "dram_routing_policy": "nearest"
  },
  "log_dram": true
}
