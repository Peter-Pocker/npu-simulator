    },
    "topology": {
        "dram_controllers": [],
        "dram_routing_policy": "nearest"
    },
    "gemini": {
        "batch_size": 1,
        "stride": 1,
        "exploration_rounds": 1,
        "opt_goal": 0,
        "sram_kb": 512,
        "nop_bw": 128,
