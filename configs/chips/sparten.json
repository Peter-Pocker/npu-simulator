{
    "_chip": "Purdue SparTen (MICRO 2019)",
    "_reference": "Gondimalla et al., SparTen: A Sparse Tensor Accelerator for Convolutional Neural Networks",
    "_notes": "Sparse tensor accelerator, inner-join based matching, 16 PEs x 16 multipliers = 256 MACs",
    "num_cores_x": 0,
    "num_cores_y": 0,
    "element_size_bits": 8,
    "core": {
        "mac_units": 256,
        "vector_units": 256,
        "clock_freq_mhz": 500.0,
        "use_analytical_time": false
    },
    "sram": {
        "size_kb": 512,
        "read_bandwidth_bytes_per_cycle": 64,
        "write_bandwidth_bytes_per_cycle": 64
    },
    "ni": {
        "max_outstanding_reqs": 16,
        "injection_queue_size": 8,
        "ejection_queue_size": 8
    },
    "noc": {
        "flit_size_bytes": 16,
        "hop_latency_cycles": 1,
        "router_latency_cycles": 1,
        "backend": "booksim2",
        "injection_queue_depth": 16,
        "num_vcs": 8,
        "vc_buf_size": 8
    },
    "dram": {
        "num_channels": 2,
        "backend": "ramulator2",
        "standard": "DDR4",
        "org": "DDR4_8Gb_x8",
        "timing": "DDR4_2400R",
        "num_ranks": 1
    }
}
