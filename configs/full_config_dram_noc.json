{
    "_comment": "Full config with DRAM controllers on NoC (1x1 core at (1,0), DRAM at (0,0) and (2,0))",
    "num_cores_x": 0,
    "num_cores_y": 0,
    "element_size_bits": 8,
    "core": {
        "mac_units": 256,
        "vector_units": 64,
        "clock_freq_mhz": 1000.0
    },
    "sram": {
        "size_kb": 512,
        "read_bandwidth_bytes_per_cycle": 64,
        "write_bandwidth_bytes_per_cycle": 64
    },
    "ni": {
        "max_outstanding_reqs": 16,
        "injection_queue_size": 8,
        "ejection_queue_size": 8
    },
    "noc": {
        "flit_size_bytes": 16,
        "hop_latency_cycles": 1,
        "router_latency_cycles": 1,
        "backend": "booksim2",
        "injection_queue_depth": 16,
        "num_vcs": 8,
        "vc_buf_size": 8,
        "routing_delay": 1,
        "vc_alloc_delay": 1,
        "sw_alloc_delay": 1,
        "st_final_delay": 1
    },
    "dram": {
        "num_channels": 4,
        "backend": "ramulator2",
        "standard": "DDR4",
        "org": "DDR4_8Gb_x8",
        "timing": "DDR4_2400R",
        "num_ranks": 2,
        "scheduler": "FRFCFS",
        "addr_mapper": "RoBaRaCoCh",
        "frontend_clock_ratio": 4
    },
    "topology": {
        "core_origin_x": 1,
        "core_origin_y": 0,
        "dram_controllers": [
            {"x": 0, "y": 0},
            {"x": 2, "y": 0}
        ],
        "dram_routing_policy": "nearest"
    },
    "ir_path": "",
    "output_path": "sim_output"
}
